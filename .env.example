# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=""

# PLANET_API_KEY: Authentication token for Planet Labs quick-search APIs
PLANET_API_KEY=""

# MONGODB_URI: Connection string for MongoDB (provided by user for farmmind database)
MONGODB_URI=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL=""

# ARIZE SETUP:
# Get space_id and api_key from Arize dashboard
ARIZE_SPACE_ID=""
ARIZE_API_KEY=""

# VITE_GOOGLE_MAPS_PLATFORM_KEY: API Key for Google Maps JavaScript API (for maps and places search).
# Set this to your Google Maps API Key in App Settings.
VITE_GOOGLE_MAPS_PLATFORM_KEY=""

